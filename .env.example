# SPAO - Security Provenance Automated OWASP
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# Neo4j (optional, for graph persistence)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Lorekeeper target repo settings (used when analyzing imports/lorekeeper) ---
# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./chroma_store/

# Guard
GUARD_MODE=permissive

# Observability
OTEL_SERVICE_NAME=lorekeeper
OTEL_EXPORTER=console
APP_ENV=development
